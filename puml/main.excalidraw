      "versionNonce": 612955945,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774929364211,
      "link": null,
      "locked": false,
      "text": "如果只是想改“状态发布频率”，主要改 pub() 相关逻辑。",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "如果只是想改“状态发布频率”，主要改 pub() 相关逻辑。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uijkHW8YlFqhnxP4vpqG6",
      "type": "text",
      "x": 4364.637032046181,
      "y": 2833.4616608517113,
      "width": 678.7598876953125,
      "height": 25,
      "angle": 0,
