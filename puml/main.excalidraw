      "isDeleted": false,
      "boundElements": null,
      "updated": 1774947489362,
      "link": null,
      "locked": false,
      "text": "torque = kp * (q_target - q_actual) + kd * (0 - qd_actual)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "torque = kp * (q_target - q_actual) + kd * (0 - qd_actual)",
      "autoResize": true,
      "lineHeight": 1.25
    },
