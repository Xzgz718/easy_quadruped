      "link": null,
      "locked": false,
      "text": "根据当前目标关节角 target_qpos 和 MuJoCo 里的实际关节位置/速度，算一组 PD\n力矩",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "根据当前目标关节角 target_qpos 和 MuJoCo 里的实际关节位置/速度，算一组 PD 力矩",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "cX1Tk2vncuPwVvqLKv8Xx",
      "type": "text",
      "x": 4916.680524918744,
      "y": 482.0737903543388,
      "width": 576.2197265625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDG",
      "roundness": null,
      "seed": 1516503689,
