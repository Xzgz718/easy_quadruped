      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "delta_foot_location = v * dt",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "KDf1pKRcb1Drh-lq8cxDL",
      "type": "text",
