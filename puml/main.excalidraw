      "isDeleted": false,
      "boundElements": null,
      "updated": 1774946776630,
      "link": null,
      "locked": false,
      "text": "rmat.T 是补偿矩阵的逆旋转。",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "rmat.T 是补偿矩阵的逆旋转。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
