      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "LwRKhphijsDMPl14U8jlr",
      "type": "text",
      "x": 194.29674096935696,
      "y": 2345.2310642753796,
      "width": 642.8799438476562,
      "height": 50,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0j",
