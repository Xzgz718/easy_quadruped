      "updated": 1774929364211,
      "link": null,
      "locked": false,
      "text": "要先看你的目的是什么：",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "要先看你的目的是什么：",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
