      "isDeleted": false,
      "boundElements": null,
      "updated": 1774945937431,
      "link": null,
      "locked": false,
      "text": "第三件：xy 平面上朝目标落脚点匀速逼近",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "第三件：xy 平面上朝目标落脚点匀速逼近",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "NngAfIQWaQ09JEdbkLgiT",
      "type": "text",
      "x": 5219.449685990748,
      "y": 4660.152134573414,
      "width": 409.01112470608456,
      "height": 21.31955721030513,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCA",
      "roundness": null,
      "seed": 854821769,
      "version": 183,
      "versionNonce": 162300263,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774945953241,
      "link": null,
      "locked": false,
      "text": "time_left = dt * swing_ticks * (1.0 - swing_prop)",
      "fontSize": 17.055645768244105,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "time_left = dt * swing_ticks * (1.0 - swing_prop)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "u_R6p_gQ7nu4AutunY7UD",
      "type": "text",
      "x": 5214.256040258498,
      "y": 4696.800888255446,
      "width": 612.8601321405458,
      "height": 21.31955721030513,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCB",
      "roundness": null,
      "seed": 1350798727,
      "version": 129,
      "versionNonce": 1007164711,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774945955711,
      "link": null,
      "locked": false,
      "text": "v = (touchdown_location - foot_location) / time_left * np.array([1, 1, 0])",
      "fontSize": 17.055645768244105,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "v = (touchdown_location - foot_location) / time_left * np.array([1, 1, 0])",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nstUMF3dKmxT5gSfApbi9",
      "type": "text",
      "x": 5213.072396491928,
      "y": 4731.93827363143,
      "width": 243.3373565673828,
      "height": 21.31955721030513,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
