    {
      "id": "MRDThmP-Jr3WW4eovFFXS",
      "type": "text",
      "x": 255.39971522805706,
      "y": 7266.22626204963,
      "width": 784.419921875,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
