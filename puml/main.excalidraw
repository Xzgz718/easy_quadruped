      "isDeleted": false,
      "boundElements": null,
      "updated": 1774946778354,
      "link": null,
      "locked": false,
      "text": "因为旋转矩阵是正交矩阵，所以：",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "因为旋转矩阵是正交矩阵，所以：",
      "autoResize": true,
      "lineHeight": 1.25
    },
