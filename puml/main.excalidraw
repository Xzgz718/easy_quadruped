      "text": "它本身不直接让狗迈步，而是修改后续 move(...) 时使用的步态节奏",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "它本身不直接让狗迈步，而是修改后续 move(...) 时使用的步态节奏",
      "autoResize": true,
      "lineHeight": 1.25
    },
