      "link": null,
      "locked": false,
      "text": "落脚点前置量，占预计支撑期水平位移的比例。",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "落脚点前置量，占预计支撑期水平位移的比例。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vFfJifktjz7W5gg7Q6IzF",
      "type": "text",
      "x": 5218.858866940963,
      "y": 3783.17986239919,
      "width": 436.7398376464844,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBi",
      "roundness": null,
      "seed": 1129106057,
      "version": 218,
      "versionNonce": 2099542665,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774945563307,
      "link": null,
      "locked": false,
      "text": "当前默认值在 Config.py (line 112) 附近是 0.5。",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "当前默认值在 Config.py (line 112) 附近是 0.5。",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "UN9Mk1UJTpWQXy5nbib25",
      "type": "text",
      "x": 5214.500499290353,
      "y": 3819.8489891853424,
      "width": 585.659912109375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
