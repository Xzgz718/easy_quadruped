      "isDeleted": true,
      "boundElements": [],
      "updated": 1774929364211,
      "link": null,
      "locked": false,
      "text": "等前面的腿部/机械臂动作走完；注意真正“等待”是这句，不是上面的\n500",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "等前面的腿部/机械臂动作走完；注意真正“等待”是这句，不是上面的 500",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "quC34AwOkxZQ7q0NN-9dC",
      "type": "text",
      "x": 48.82973001912035,
      "y": 2231.9854650926195,
      "width": 590.3799438476562,
      "height": 25,
      "angle": 0,
