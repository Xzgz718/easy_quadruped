@startuml
title Stanford Quadruped Sim Floating Architecture

skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName Consolas
skinparam packageStyle rectangle
skinparam wrapWidth 220
skinparam maxMessageSize 200
left to right direction

legend right
  sim float = sim/run_floating_base.py
  Main loop:
  TaskScheduler -> Command -> Controller -> IK -> PD torque -> MuJoCo -> Observation -> State
endlegend

package "Startup" {
  component "CLI Args\nparse_args()" as CLI
  component "run_floating_base.py\nmain()" as Main
  component "build_floating_base_mjcf.py\nbuild_mjcf()" as Builder
  database "pupper_floating.xml" as XML
  component "MuJoCo\nMjModel + MjData" as MJ
}

package "Controller Side" {
  component "Configuration" as Config
  component "Controller" as Controller
  component "four_legs_inverse_kinematics()" as IK
  component "State" as State
  component "Command" as Command
}

package "Sim Adapters" {
  component "TaskCommandSource" as CommandSource
  component "TaskScheduler" as Scheduler
  component "SimObservationInterface" as Obs
  component "SimIMU" as IMU
  component "SimHardwareInterface\nPD torque tracker" as HW
  component "SimControlClock" as Clock
}

package "Viewer / Output" {
  component "MuJoCo Viewer" as Viewer
  component "Live Plots\npitch / vx / contacts" as Plots
  component "Telemetry Print" as Telemetry
}

CLI --> Main : args
Main --> Builder : --rebuild / xml missing / stale
Builder --> XML : generate
Main --> XML : load xml
Main --> MJ : create model/data

Main --> Config : initialize_controller()
Main --> Controller : construct
Main --> State : construct
Controller --> IK : use IK callback

Main --> Obs : create
Main --> IMU : create
Main --> HW : create\nkp/kd/torque_limit
Main --> Clock : create
Main --> CommandSource : create_command_source()
CommandSource --> Scheduler : build from args\nmode/settle/task-sequence

HW --> MJ : set_initial_pose()
Obs --> State : sync_state()\ninitial measurement write-back
IMU --> State : quat_orientation

package "Per Control Tick" {
  component "1. sync_state()" as TickObs
  component "2. apply_step_config()" as TickStepCfg
  component "3. get_command()" as TickCmd
  component "4. apply_feedback()" as TickFeedback
  component "5. controller.run()" as TickController
  component "6. set_actuator_postions()" as TickTargets
  component "7. hardware_interface.step()" as TickStep
  component "8. viewer / plots / telemetry" as TickViz
}

MJ --> TickObs
TickObs --> Obs
Obs --> State : body pose\nbody velocity\nangular velocity\njoint states\nfoot states\ncontact estimate

State --> TickStepCfg
TickStepCfg --> CommandSource
CommandSource --> Scheduler : current step\ntransition blend
TickStepCfg --> Config : z_clearance\noverlap_time\nswing_time

State --> TickCmd
TickCmd --> CommandSource
CommandSource --> Command : activate_event\ntrot_event\nvx/vy/yaw\nheight/pitch/roll

State --> TickFeedback
Command --> TickFeedback
TickFeedback --> Command : attitude_kp/kd\nvelocity_kp correction

State --> TickController
Command --> TickController
Config --> TickController
TickController --> Controller
Controller --> State : desired foot_locations\njoint_angles\nbehavior_state

State --> TickTargets
TickTargets --> HW : target joint angles

HW --> TickStep
TickStep --> MJ : PD torque + mj_step()

State --> TickViz
Obs --> TickViz : telemetry_line()\npose_error()\ncontact_forces()
TickViz --> Telemetry
TickViz --> Viewer
TickViz --> Plots
Viewer --> MJ : sync()
Clock --> TickStep : control_interval substeps
TickViz --> Clock : finish_tick()

note bottom of Obs
Reads MuJoCo sensors and writes back into State:
- measured_joint_angles / velocities
- measured_foot_locations
- body_position / body_velocity
- angular_velocity / quat_orientation
- foot_forces / contact_estimate
end note

note bottom of HW
Tracks joint targets with PD torques:
torque = clip(kp * position_error + kd * velocity_error)
end note

note bottom of CommandSource
Bridges task-level scheduling to robot-style commands.
Supports activation delay, per-step overrides,
and smooth transition_time blending.
end note

@enduml
