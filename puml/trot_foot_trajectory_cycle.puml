@startuml
title Trot Foot Trajectory Over One Gait Cycle\n(diagonal pairs, phase by phase)

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Consolas
skinparam wrapWidth 240
skinparam maxMessageSize 220
skinparam linetype ortho
skinparam ArrowThickness 2
skinparam nodesep 100
skinparam ranksep 120
left to right direction

caption This is a teaching diagram for the foot-motion meaning of the gait schedule.\nPair A = FR + BL. Pair B = FL + BR. In this project, each pair alternates between stance and swing,\nwith overlap phases in between. Stance means ground contact + backward sweep in the body frame; swing means lift + forward return + touchdown.

package "1. Motion Primitives" {
  component "Stance primitive\ncontact with ground\nx moves backward in body frame\nz stays near commanded height" as StancePrimitive
  component "Swing primitive\nlift foot -> move forward -> lower foot\ntouchdown near predicted target" as SwingPrimitive
  component "Code path\nStanceController + SwingController" as CodePath

  StancePrimitive -[hidden]right-> SwingPrimitive
  SwingPrimitive -[hidden]down-> CodePath
}

package "2. Phase 0\nOverlap\n16 ticks" {
  component "Pair A\nFR + BL\nSTANCE" as A0
  component "Pair B\nFL + BR\nSTANCE" as B0
}

package "3. Phase 1\nDiagonal exchange\n11 ticks" {
  component "Pair A\nFR + BL\nSTANCE" as A1
  component "Pair B\nFL + BR\nSWING" as B1
}

package "4. Phase 2\nOverlap\n16 ticks" {
  component "Pair A\nFR + BL\nSTANCE" as A2
  component "Pair B\nFL + BR\nSTANCE" as B2
}

package "5. Phase 3\nDiagonal exchange\n11 ticks" {
  component "Pair A\nFR + BL\nSWING" as A3
  component "Pair B\nFL + BR\nSTANCE" as B3
}

package "6. Meaning Across the Whole Cycle" {
  component "Pair A cycle\nstance -> stance -> stance -> swing" as PairA
  component "Pair B cycle\nstance -> swing -> stance -> stance" as PairB
  component "Result\nconservative diagonal trot\nwith overlap" as Meaning

  PairA -[hidden]down-> PairB
  PairB -[hidden]right-> Meaning
}

StancePrimitive --> A0
StancePrimitive --> B0
StancePrimitive --> A1
SwingPrimitive --> B1
StancePrimitive --> A2
StancePrimitive --> B2
SwingPrimitive --> A3
StancePrimitive --> B3

CodePath --> A1 : contact_mode == 1\n-> StanceController
CodePath --> B1 : contact_mode == 0\n-> SwingController
CodePath --> A3 : contact_mode == 0\n-> SwingController
CodePath --> B3 : contact_mode == 1\n-> StanceController

A0 --> A1 : stay on ground\ncontinue backward sweep
A1 --> A2 : stay on ground\nsupport body
A2 --> A3 : lift -> forward arc -> touchdown
A3 --> PairA : repeat next cycle

B0 --> B1 : lift -> forward arc -> touchdown
B1 --> B2 : stay on ground\nsupport body
B2 --> B3 : stay on ground\ncontinue backward sweep
B3 --> PairB : repeat next cycle

A0 --> PairA
A1 --> PairA
A2 --> PairA
B0 --> PairB
B1 --> PairB
B2 --> PairB
PairA --> Meaning
PairB --> Meaning

@enduml
